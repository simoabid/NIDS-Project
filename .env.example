# ─────────────────────────────────────────────────────────────────────────────
# NIDS — Environment Variables Template
# Copy this file to .env and fill in your values before running docker-compose.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB ────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme
MONGO_DB=nids

# ── JWT Auth ───────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ── Grafana ────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme

# ── Frontend (Vite build-time env vars — must be prefixed with VITE_) ──────
VITE_API_URL=http://localhost:5000
VITE_WS_URL=http://localhost:5000

# ── AI Service ─────────────────────────────────────────────────────────────
# AI_SERVICE_URL is set internally in docker-compose (http://ai-service:8000)
# Override here only if running the AI service outside of Docker
# AI_SERVICE_URL=http://localhost:8000

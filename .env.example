# ─────────────────────────────────────────────────────────────────────────────
# NIDS — Environment Variables Template
# Copy this file to .env and fill in your values before running docker-compose.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB ────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme
MONGO_DB=nids

# ── JWT Auth ───────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret_string
JWT_REFRESH_EXPIRES_IN=7d

# ── Grafana ────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme

# ── Frontend (Vite build-time env vars — must be prefixed with VITE_) ──────
VITE_API_URL=http://localhost:5000
VITE_WS_URL=http://localhost:5000

# ── AI Service ─────────────────────────────────────────────────────────────
# AI_SERVICE_URL is set internally in docker-compose (http://ai-service:8000)
# Override here only if running the AI service outside of Docker
# AI_SERVICE_URL=http://localhost:8000

# ── Suricata / Capture ─────────────────────────────────────────────────────
# CAPTURE_MODE: "live" (default) or "pcap" (replay a file for dev/testing)
CAPTURE_MODE=live
# Path to a .pcap file for replay mode (only used when CAPTURE_MODE=pcap)
# CAPTURE_PCAP_PATH=/path/to/test.pcap
# Suricata binary location
# SURICATA_BIN=/usr/bin/suricata
# Directory where Suricata writes eve.json
# SURICATA_EVE_DIR=/var/log/suricata
# Full path to eve.json (overrides EVE_DIR if set)
# Local dev: /tmp/suricata-logs/eve.json
# Docker:    /var/log/suricata/eve.json
SURICATA_EVE_LOG=

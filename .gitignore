# ─────────────────────────────────────────────────────────────────────────────
# NIDS — Root .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets (never commit) ────────────────────────────────────────────────────
# Pattern without a leading slash matches at ANY depth (root, backend/, etc.)
.env
*.pem
*.key
*.crt

# ── Node.js ──────────────────────────────────────────────────────────────────
node_modules/
dist/
build/
.npm/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.eggs/

# ── AI / ML artefacts ─────────────────────────────────────────────────────────
# Serialised Scikit-Learn models
*.pkl
# TensorFlow / Keras model weights
*.h5
# ONNX exported models
*.onnx
# Datasets (store in DVC or a data lake instead)
*.csv
*.parquet
# NSL-KDD dataset uses .txt — ignore large data files in ai-service/data/
ai-service/data/*.txt
# Keep JSON metadata (feature_columns.json, model_metadata.json) — they're small & text
!ai-service/model/*.json

# ── Network captures ──────────────────────────────────────────────────────────
*.pcap
*.pcapng
*.cap

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
.agent/
.agents/
skills-lock.json

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Docker ────────────────────────────────────────────────────────────────────
# Don't ignore docker-compose.yml — it's committed.
# Do ignore any local override files:
docker-compose.override.yml

# ── Test coverage ─────────────────────────────────────────────────────────────
coverage/
.nyc_output/
htmlcov/

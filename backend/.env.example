# ─────────────────────────────────────────────────────────────────────────────
# Backend — Environment Variables Template
# backend/.env.example
#
# ✅ This file IS committed to Git.
#    It documents every variable the backend needs without exposing real values.
#    To get started: cp backend/.env.example backend/.env
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=
PORT=

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local dev:  mongodb://localhost:27017/nids
# Docker:     mongodb://admin:<password>@mongo:27017/nids?authSource=admin
MONGO_URI=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local dev:  redis://localhost:6379
# Docker:     redis://redis:6379
REDIS_URL=

# ── JWT — Access Token ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRES_IN=

# ── JWT — Refresh Token ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48  (use a DIFFERENT value from JWT_SECRET)
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=

# ── AI Service ────────────────────────────────────────────────────────────────
# Local dev:  http://localhost:8000
# Docker:     http://ai-service:8000
AI_SERVICE_URL=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=    # e.g. 900000 (15 minutes in ms)
RATE_LIMIT_MAX_REQUESTS= # e.g. 100

# ── Logging ───────────────────────────────────────────────────────────────────
# Levels: error | warn | info | http | debug
LOG_LEVEL=

# ── Audit Layer ───────────────────────────────────────────────────────────────
AUDIT_LOG_ENABLED=
